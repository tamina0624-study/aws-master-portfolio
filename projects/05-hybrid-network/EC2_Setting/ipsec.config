#/etc/ipsec.conf
#最重要。 トンネルの接続先（Right IP）、IKE/ESPの暗号化アルゴリズム、Mark（10/11）、VTIスクリプトの指定などを行います。




config setup
    charondebug="ike 2, knl 2, cfg 2"

# --- Tunnel 1 設定 (AWS EndPoint: 3.129.118.107) ---
conn aws-vpn-t1
    keyexchange=ikev2
    ike=aes128-sha1-modp1024,aes256-sha256-modp2048!
    esp=aes128-sha1-modp1024,aes256-sha256-modp2048!
    authby=psk
    auto=start
    type=tunnel
    left=%defaultroute
    leftid=3.15.49.151
    leftsubnet=0.0.0.0/0
    right=3.129.118.107
    rightid=3.129.118.107
    rightsubnet=0.0.0.0/0
    installpolicy=yes
    mark=10
    leftupdown=/etc/strongswan.d/ipsec-vti.sh

# --- Tunnel 2 設定 (AWS EndPoint: 18.223.13.191) ---
conn aws-vpn-t2
    keyexchange=ikev2
    ike=aes128-sha1-modp1024,aes256-sha256-modp2048!
    esp=aes128-sha1-modp1024,aes256-sha256-modp2048!
    authby=psk
    auto=start
    type=tunnel
    left=%defaultroute
    leftid=3.15.49.151
    leftsubnet=0.0.0.0/0
    right=18.223.13.191
    rightid=18.223.13.191
    rightsubnet=0.0.0.0/0
    installpolicy=yes
    mark=11
    leftupdown=/etc/strongswan.d/ipsec-vti.sh
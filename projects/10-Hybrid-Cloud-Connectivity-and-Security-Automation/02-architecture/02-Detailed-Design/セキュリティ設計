【Lambda（攻撃元IPブロック）】
name: hcsa-lambda-block_attacker_ip_port
region: us-east-2
runtime: python3.8
handler: lambda_function.lambda_handler
timeout: 3s
memory: 128mb
trigger: EventBridge: guardduty-finding-to-lambda
execRole: hcsa-lambda-role

■ACL
【prod-hcsa-vpc-acl】
inbound-rule
deny deny-ipset all
permit allow-ipset all

outbound-rule
deny deny-ipset all
permit allow-ipset all

【onprem-hcsa-vpc-acl】
inbound-rule
deny deny-ipset all
permit allow-ipset all

outbound-rule
deny deny-ipset all
permit allow-ipset all

■security group
【prod-hcsa-vpc-sg】
inbound-rule
allow-ipset all

outbound-rule
allow-ipset all

【onprem-hcsa-vpc-sg】
inbound-rule
allow-ipset all

outbound-rule
allow-ipset all

【prod-hcsa-vpc-rds-sg】
inbound-rule
prod-hcsa-vpc-sg 3306

outbound-rule
allow-ipset all
